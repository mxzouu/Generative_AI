# Copiez ce fichier en « .env » (même dossier) et remplissez vos valeurs.
# Le vrai .env est gitignoré — ne committez JAMAIS votre clé API.

# --- Obligatoire ---------------------------------------------------------------
# Clé API Anthropic (modèle Haiku uniquement pour ce projet).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Envoi d'emails (optionnel) ------------------------------------------------
# Sans SMTP_APP_PASSWORD, l'app fonctionne en mode « simulation » : les emails ne
# sont pas envoyés, ils sont journalisés dans data/outbox.log.
# Pour un envoi réel via Gmail : mot de passe d'application (pas le mot de passe du compte).
SMTP_USER=votre.adresse@gmail.com
SMTP_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Avancé (optionnel) --------------------------------------------------------
# Forcent l'interpréteur / le chemin du serveur MCP lancé en sous-processus.
# Laissez vides : par défaut l'app utilise le python courant et app/credit_server.py.
# CREDIT_MCP_PYTHON=
# CREDIT_MCP_SERVER=
